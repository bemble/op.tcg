# Node / frontend
node_modules/
frontend/dist/
# Vite writes these temp files when loading a TS config; never commit them.
frontend/vite.config.ts.timestamp-*

# Go
/server
backend/server
backend/optcg
/optcg
# go.work is committed (enables `go run ./backend` from root); its sum is not.
go.work.sum

# Local data & secrets
*.db
*.db-shm
*.db-wal
data/
.env

# catalogue.json is NOT committed: each container rebuilds it on first run
# via the startup background sync (SYNC_ON_START). Ignore the local dev copy,
# the atomic-write temp file, and any copy under backend/.
catalogue.json
catalogue.json.tmp
backend/catalogue.json

# Editor / OS
.claude
.DS_Store
.idea/
.vscode/
